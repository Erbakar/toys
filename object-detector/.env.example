# Mock servisi kullan (true → MockDetectionService, false → ApiDetectionService)
VITE_USE_MOCK=true

# ApiDetectionService için FastAPI backend adresi
# VITE_USE_MOCK=false olduğunda gereklidir
# Vercel deploy'da localhost kullanmayın; public HTTPS backend URL girin.
# Örn: VITE_API_URL=https://object-detector-api.example.com
VITE_API_URL=http://localhost:8000
